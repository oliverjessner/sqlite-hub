{
    "name": "sqlite-hub",
    "version": "1.3.0",
    "description": "SQLite-only local management app backend and SPA shell",
    "license": "MIT",
    "main": "server/server.js",
    "bin": {
        "sqlite-hub": "bin/sqlite-hub.js"
    },
    "scripts": {
        "build": "npm run build:css",
        "build:css": "tailwindcss -i ./frontend/styles/tailwind.css -o ./frontend/styles/tailwind.generated.css --minify",
        "audit": "npm audit --audit-level=high",
        "test": "node --test tests/**/*.test.js",
        "start": "node bin/sqlite-hub.js",
        "dev": "node --watch server/server.js --port:4180",
        "prepack": "npm run build:css",
        "publish": "bash scripts/publish_brew.sh && sleep 10 && npm login --auth-type=web && bash scripts/publish_npm.sh",
        "screenshots": "node scripts/screenshot_sqlite_hub.js --width:1920 --height:1280"
    },
    "dependencies": {
        "better-sqlite3": "^12.10.1",
        "cytoscape": "^3.34.0",
        "cytoscape-elk": "^2.3.0",
        "dotenv": "^17.4.2",
        "echarts": "^6.1.0",
        "elkjs": "^0.11.1",
        "express": "^5.2.1",
        "express-rate-limit": "^8.5.2",
        "helmet": "^8.2.0",
        "marked": "^18.0.5",
        "material-symbols": "^0.45.1",
        "parquetjs-lite": "^0.8.7"
    },
    "devDependencies": {
        "@tailwindcss/cli": "^4.3.1",
        "@tailwindcss/container-queries": "^0.1.1",
        "@tailwindcss/forms": "^0.5.11",
        "tailwindcss": "^4.3.1"
    }
}
